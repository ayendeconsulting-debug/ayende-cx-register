generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                     String                  @id @default(uuid())
  externalTenantId       String?                 @unique
  businessName           String
  businessAddress        String?
  businessCity           String?
  businessState          String?
  businessZipCode        String?
  businessCountry        String?
  businessPhone          String?
  businessEmail          String?
  businessWebsite        String?
  logoUrl                String?
  primaryColor           String?                 @default("#3B82F6")
  secondaryColor         String?                 @default("#10B981")
  currency               String                  @default("$")
  currencyCode           String                  @default("USD")
  timezone               String                  @default("America/Toronto")
  dateFormat             String                  @default("MM/DD/YYYY")
  timeFormat             String                  @default("12")
  taxEnabled             Boolean                 @default(true)
  taxRate                Decimal                 @default(0.00) @db.Decimal(5, 4)
  taxLabel               String                  @default("Tax")
  taxNumber              String?
  receiptHeader          String?
  receiptFooter          String?
  loyaltyEnabled         Boolean                 @default(true)
  isActive               Boolean                 @default(true)
  subscriptionTier       String?                 @default("BASIC")
  subscriptionExpiry     DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  lastSyncedAt           DateTime?               @db.Timestamp(6)
  syncStatus             SyncStatus?             @default(PENDING)
  subdomain              String?                 @unique
  defaultDepositPercent  Decimal?                @default(25) @db.Decimal(5, 2)
  overdueGracePeriodDays Int?                    @default(0)
  rentalEnabled          Boolean                 @default(false)
  currencyPosition       String                  @default("before")
  decimalPlaces          Int                     @default(2)
  decimalSeparator       String                  @default(".")
  thousandsSeparator     String                  @default(",")
  Category               Category[]
  Customer               Customer[]
  LoyaltyReconciliation  LoyaltyReconciliation[]
  LoyaltyTransaction     LoyaltyTransaction[]
  Product                Product[]
  Shift                  Shift[]
  SyncQueue              SyncQueue[]
  SystemMapping          SystemMapping[]
  Transaction            Transaction[]
  User                   User[]
  UserInvitation         UserInvitation[]
  rental_contracts       rental_contracts[]
  stock_adjustments      stock_adjustments[]
  sync_logs              sync_logs[]
  terms_acceptances      terms_acceptances[]

  @@index([businessName])
  @@index([externalTenantId])
}

model Product {
  id                     String                   @id @default(uuid())
  sku                    String
  name                   String
  description            String?
  categoryId             String
  price                  Decimal                  @db.Decimal(10, 2)
  costPrice              Decimal?                 @db.Decimal(10, 2)
  stockQuantity          Int                      @default(0)
  lowStockAlert          Int                      @default(10)
  unit                   String                   @default("unit")
  barcode                String?
  imageUrl               String?
  isActive               Boolean                  @default(true)
  isTaxable              Boolean                  @default(true)
  loyaltyPoints          Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  businessId             String
  currency               String                   @default("$")
  currencyCode           String                   @default("USD")
  dailyRate              Decimal?                 @db.Decimal(10, 2)
  depositAmount          Decimal?                 @db.Decimal(10, 2)
  hourlyRate             Decimal?                 @db.Decimal(10, 2)
  isRental               Boolean                  @default(false)
  latePenaltyRate        Decimal?                 @db.Decimal(10, 2)
  maxRentalDuration      Int?
  minRentalDuration      Int?                     @default(1)
  requiresDeposit        Boolean                  @default(true)
  weeklyRate             Decimal?                 @db.Decimal(10, 2)
  Business               Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Category               Category                 @relation(fields: [categoryId], references: [id])
  StockMovement          StockMovement[]
  TransactionItem        TransactionItem[]
  rental_contract_items  rental_contract_items[]
  stock_adjustments      stock_adjustments[]
  stock_movement_history stock_movement_history[]

  @@unique([businessId, barcode])
  @@unique([businessId, sku])
  @@index([name])
  @@index([barcode])
  @@index([businessId])
  @@index([categoryId])
  @@index([isRental])
  @@index([sku])
}

model Transaction {
  id                    String            @id @default(uuid())
  transactionNumber     String
  customerId            String?
  userId                String
  subtotal              Decimal           @db.Decimal(10, 2)
  taxAmount             Decimal           @db.Decimal(10, 2)
  discountAmount        Decimal           @default(0) @db.Decimal(10, 2)
  total                 Decimal           @db.Decimal(10, 2)
  paymentMethod         PaymentMethod
  amountPaid            Decimal           @db.Decimal(10, 2)
  changeGiven           Decimal           @default(0) @db.Decimal(10, 2)
  loyaltyPointsEarned   Int               @default(0)
  loyaltyPointsRedeemed Int               @default(0)
  status                TransactionStatus @default(COMPLETED)
  voidReason            String?
  shiftId               String?
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  businessId            String
  currency              String            @default("$")
  currencyCode          String            @default("CAD")
  externalId            String?
  syncedAt              DateTime?
  syncedToCRM           Boolean           @default(false)
  syncStatus            SyncStatus?       @default(PENDING)
  syncedToCrm           Boolean?          @default(false)
  lastSyncedAt          DateTime?
  syncError             String?
  transactionType       TransactionType   @default(SALE)
  StockMovement         StockMovement[]
  Business              Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Customer              Customer?         @relation(fields: [customerId], references: [id])
  Shift                 Shift?            @relation(fields: [shiftId], references: [id])
  User                  User              @relation(fields: [userId], references: [id])
  TransactionItem       TransactionItem[]
  rental_contracts      rental_contracts?

  @@unique([businessId, transactionNumber])
  @@index([businessId])
  @@index([createdAt])
  @@index([customerId])
  @@index([externalId])
  @@index([shiftId])
  @@index([status])
  @@index([syncedToCRM])
  @@index([syncedToCrm])
  @@index([transactionType])
  @@index([userId])
}

model LoyaltyTransaction {
  id            String                 @id @default(uuid())
  customerId    String
  type          LoyaltyTransactionType
  points        Int
  transactionId String?
  description   String
  expiresAt     DateTime?
  createdAt     DateTime               @default(now())
  businessId    String
  Business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Customer      Customer               @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([createdAt])
  @@index([customerId])
}

model AuditLog {
  id         String      @id
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  changes    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())
  User       User?       @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
}

model Category {
  id          String    @id
  name        String
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  businessId  String
  Business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Product     Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@index([name])
}

model Customer {
  id                    String                  @id
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?
  loyaltyPoints         Int                     @default(0)
  totalSpent            Decimal                 @default(0) @db.Decimal(10, 2)
  visitCount            Int                     @default(0)
  lastVisit             DateTime?
  memberSince           DateTime                @default(now())
  loyaltyTier           LoyaltyTier             @default(BRONZE)
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  marketingOptIn        Boolean                 @default(false)
  isActive              Boolean                 @default(true)
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  businessId            String
  externalId            String?
  lastSyncedAt          DateTime?
  customerSource        CustomerSource?         @default(POS)
  isAnonymous           Boolean?                @default(false)
  lastRefreshedAt       DateTime?               @db.Timestamp(6)
  loyaltyLastSyncedAt   DateTime?               @db.Timestamp(6)
  loyaltyPointsCRM      Int?
  loyaltyPointsLocal    Int?                    @default(0)
  needsEnrichment       Boolean?                @default(false)
  syncError             String?
  syncRetryCount        Int?                    @default(0)
  syncState             CustomerSyncState?      @default(PENDING)
  syncStatus            SyncStatus?             @default(PENDING)
  Business              Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  LoyaltyReconciliation LoyaltyReconciliation[]
  LoyaltyTransaction    LoyaltyTransaction[]
  Transaction           Transaction[]
  rental_contracts      rental_contracts[]

  @@unique([businessId, email])
  @@unique([businessId, phone])
  @@index([businessId])
  @@index([customerSource])
  @@index([email])
  @@index([externalId])
  @@index([isAnonymous])
  @@index([loyaltyTier])
  @@index([phone])
  @@index([syncState])
}

model LoyaltyReconciliation {
  id           String    @id
  businessId   String
  customerId   String
  detectedAt   DateTime  @default(now())
  posPoints    Int
  crmPoints    Int
  discrepancy  Int
  action       String?
  status       String    @default("PENDING")
  resolvedBy   String?
  resolvedAt   DateTime?
  notes        String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  Business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId])
  @@index([detectedAt])
  @@index([status])
}

model Shift {
  id           String        @id
  userId       String
  shiftNumber  String
  openingCash  Decimal       @db.Decimal(10, 2)
  closingCash  Decimal?      @db.Decimal(10, 2)
  expectedCash Decimal?      @db.Decimal(10, 2)
  variance     Decimal?      @db.Decimal(10, 2)
  status       ShiftStatus   @default(OPEN)
  openedAt     DateTime      @default(now())
  closedAt     DateTime?
  notes        String?
  businessId   String
  Business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  User         User          @relation(fields: [userId], references: [id])
  Transaction  Transaction[]

  @@unique([businessId, shiftNumber])
  @@index([businessId])
  @@index([openedAt])
  @@index([status])
  @@index([userId])
}

model StockMovement {
  id            String            @id
  productId     String
  quantity      Int
  previousStock Int
  newStock      Int
  reference     String?
  notes         String?
  createdAt     DateTime          @default(now())
  movementType  StockMovementType
  transactionId String?
  Product       Product           @relation(fields: [productId], references: [id])
  Transaction   Transaction?      @relation(fields: [transactionId], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@index([transactionId])
}

model SyncQueue {
  id           String       @id
  businessId   String
  entityType   EntityType
  entityId     String
  operation    String
  priority     SyncPriority @default(NORMAL)
  status       QueueStatus  @default(PENDING)
  retryCount   Int          @default(0)
  scheduledFor DateTime     @default(now())
  processedAt  DateTime?
  error        String?
  payload      Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  Business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([scheduledFor])
  @@index([status, priority])
}

model SystemConfig {
  id          String   @id
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime

  @@index([key])
}

model SystemMapping {
  id           String            @id
  entityType   EntityMappingType
  posId        String
  crmId        String
  businessId   String
  lastSyncedAt DateTime          @default(now()) @db.Timestamp(6)
  syncStatus   SyncStatus        @default(PENDING)
  metadata     Json?
  createdAt    DateTime          @default(now()) @db.Timestamp(6)
  updatedAt    DateTime          @default(now()) @db.Timestamp(6)
  Business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([entityType, crmId])
  @@unique([entityType, posId])
  @@index([businessId])
  @@index([entityType, syncStatus])
}

model TransactionItem {
  id            String      @id
  transactionId String
  productId     String
  productName   String
  sku           String
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  tax           Decimal     @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
  currency      String      @default("$")
  currencyCode  String      @default("CAD")
  dailyRate     Decimal?    @db.Decimal(10, 2)
  isRentalItem  Boolean     @default(false)
  rentalDays    Int?
  Product       Product     @relation(fields: [productId], references: [id])
  Transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([transactionId])
}

model User {
  id                                                   String                       @id
  email                                                String
  username                                             String
  passwordHash                                         String
  firstName                                            String
  lastName                                             String
  role                                                 UserRole                     @default(CASHIER)
  isActive                                             Boolean                      @default(true)
  lastLogin                                            DateTime?
  createdAt                                            DateTime                     @default(now())
  updatedAt                                            DateTime
  businessId                                           String
  passwordResetExpires                                 DateTime?
  passwordResetToken                                   String?
  AuditLog                                             AuditLog[]
  Shift                                                Shift[]
  Transaction                                          Transaction[]
  Business                                             Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  UserInvitation                                       UserInvitation[]
  rental_contracts                                     rental_contracts[]
  stock_adjustment_approvals                           stock_adjustment_approvals[]
  stock_adjustments_stock_adjustments_approvedByToUser stock_adjustments[]          @relation("stock_adjustments_approvedByToUser")
  stock_adjustments_stock_adjustments_createdByToUser  stock_adjustments[]          @relation("stock_adjustments_createdByToUser")
  stock_movement_history                               stock_movement_history[]

  @@unique([businessId, email])
  @@unique([businessId, username])
  @@index([businessId])
  @@index([email])
  @@index([username])
}

model UserInvitation {
  id              String           @id
  businessId      String
  email           String
  firstName       String
  lastName        String
  role            UserRole
  invitationToken String           @unique
  expiresAt       DateTime
  invitedBy       String
  message         String?
  status          InvitationStatus @default(PENDING)
  acceptedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  Business        Business         @relation(fields: [businessId], references: [id])
  User            User             @relation(fields: [invitedBy], references: [id])

  @@index([businessId])
  @@index([email])
  @@index([invitationToken])
  @@index([status])
}

model rental_contract_items {
  id                String           @id
  contractId        String
  productId         String
  productName       String
  sku               String
  quantity          Int
  dailyRate         Decimal          @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  returnedQuantity  Int              @default(0)
  damagedQuantity   Int              @default(0)
  missingQuantity   Int              @default(0)
  damageDescription String?
  damageCharge      Decimal          @default(0) @db.Decimal(10, 2)
  createdAt         DateTime         @default(now())
  returnedAt        DateTime?
  rental_contracts  rental_contracts @relation(fields: [contractId], references: [id], onDelete: Cascade)
  Product           Product          @relation(fields: [productId], references: [id])

  @@index([contractId])
  @@index([productId])
}

model rental_contracts {
  id                    String                  @id
  contractNumber        String
  businessId            String
  customerId            String
  transactionId         String?                 @unique
  startDate             DateTime
  expectedReturnDate    DateTime
  actualReturnDate      DateTime?
  rentalDays            Int
  subtotal              Decimal                 @db.Decimal(10, 2)
  taxAmount             Decimal                 @default(0) @db.Decimal(10, 2)
  depositAmount         Decimal                 @db.Decimal(10, 2)
  depositReturned       Decimal?                @db.Decimal(10, 2)
  penaltyAmount         Decimal                 @default(0) @db.Decimal(10, 2)
  damageCharges         Decimal                 @default(0) @db.Decimal(10, 2)
  totalDue              Decimal                 @db.Decimal(10, 2)
  totalPaid             Decimal                 @default(0) @db.Decimal(10, 2)
  balanceDue            Decimal                 @default(0) @db.Decimal(10, 2)
  currency              String                  @default("$")
  currencyCode          String                  @default("CAD")
  status                RentalStatus            @default(ACTIVE)
  returnedBy            String?
  returnNotes           String?
  damageNotes           String?
  contactPhone          String?
  contactEmail          String?
  deliveryAddress       String?
  overdueNotified       Boolean                 @default(false)
  overdueNotifiedAt     DateTime?
  reminderSent          Boolean                 @default(false)
  reminderSentAt        DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  closedAt              DateTime?
  rentalPaymentUpfront  Decimal                 @default(0) @db.Decimal(10, 2)
  rental_contract_items rental_contract_items[]
  Business              Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Customer              Customer                @relation(fields: [customerId], references: [id])
  User                  User?                   @relation(fields: [returnedBy], references: [id])
  Transaction           Transaction?            @relation(fields: [transactionId], references: [id])

  @@unique([businessId, contractNumber])
  @@index([businessId])
  @@index([customerId])
  @@index([expectedReturnDate])
  @@index([startDate])
  @@index([status])
}

model stock_adjustment_approvals {
  id                String            @id
  adjustmentId      String            @unique
  status            ApprovalStatus    @default(PENDING)
  approvedBy        String?
  decision          String?
  rejectionReason   String?
  approvalNotes     String?
  submittedAt       DateTime          @default(now())
  reviewedAt        DateTime?
  stock_adjustments stock_adjustments @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  User              User?             @relation(fields: [approvedBy], references: [id])

  @@index([status])
  @@index([submittedAt])
}

model stock_adjustments {
  id                                      String                      @id
  adjustmentNumber                        String
  productId                               String
  adjustmentType                          AdjustmentType
  quantityBefore                          Int
  quantityChange                          Int
  quantityAfter                           Int
  unitCost                                Decimal                     @db.Decimal(10, 2)
  totalValue                              Decimal                     @db.Decimal(10, 2)
  reason                                  AdjustmentReason
  customReason                            String?
  notes                                   String?
  status                                  AdjustmentStatus            @default(PENDING)
  requiresApproval                        Boolean                     @default(false)
  createdBy                               String
  approvedBy                              String?
  createdAt                               DateTime                    @default(now())
  processedAt                             DateTime?
  businessId                              String
  stock_adjustment_approvals              stock_adjustment_approvals?
  User_stock_adjustments_approvedByToUser User?                       @relation("stock_adjustments_approvedByToUser", fields: [approvedBy], references: [id])
  Business                                Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  User_stock_adjustments_createdByToUser  User                        @relation("stock_adjustments_createdByToUser", fields: [createdBy], references: [id])
  Product                                 Product                     @relation(fields: [productId], references: [id])
  stock_movement_history                  stock_movement_history?

  @@unique([businessId, adjustmentNumber])
  @@index([businessId])
  @@index([createdAt])
  @@index([createdBy])
  @@index([productId])
  @@index([status])
}

model stock_movement_history {
  id                String                 @id
  movementType      AdjustmentMovementType
  referenceId       String
  referenceType     String
  productId         String
  adjustmentId      String?                @unique
  quantityBefore    Int
  quantityChange    Int
  quantityAfter     Int
  unitCost          Decimal                @db.Decimal(10, 2)
  totalValue        Decimal                @db.Decimal(10, 2)
  reason            String
  notes             String?
  performedBy       String
  createdAt         DateTime               @default(now())
  stock_adjustments stock_adjustments?     @relation(fields: [adjustmentId], references: [id])
  User              User                   @relation(fields: [performedBy], references: [id])
  Product           Product                @relation(fields: [productId], references: [id])

  @@index([createdAt])
  @@index([movementType])
  @@index([performedBy])
  @@index([productId])
}

model sync_logs {
  id           String     @id
  businessId   String
  operation    String
  direction    String
  entityType   String
  entityId     String
  status       SyncStatus @default(PENDING)
  attemptCount Int        @default(1)
  errorMessage String?
  payload      String
  response     String?
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  nextRetryAt  DateTime?
  Business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([status])
}

model terms_acceptances {
  id              String         @id
  businessId      String
  termsVersionId  String
  acceptedBy      String?
  acceptedByEmail String
  acceptedByName  String
  acceptedAt      DateTime       @default(now())
  ipAddress       String?
  userAgent       String?
  Business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  terms_versions  terms_versions @relation(fields: [termsVersionId], references: [id])

  @@unique([businessId, termsVersionId])
  @@index([acceptedAt])
  @@index([businessId])
  @@index([termsVersionId])
}

model terms_versions {
  id                String              @id
  version           String              @unique
  documentType      TermsDocumentType
  title             String
  effectiveDate     DateTime
  content           String?
  contentUrl        String?
  changelog         String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  terms_acceptances terms_acceptances[]

  @@index([documentType, isActive])
  @@index([effectiveDate])
}

enum TransactionType {
  SALE
  RENTAL
  REFUND
  EXCHANGE
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  LOYALTY_POINTS
  SPLIT
  MOBILE
  OTHER
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum AdjustmentMovementType {
  ADJUSTMENT
  SALE
  PURCHASE
  TRANSFER
  RETURN
  RENTAL_OUT
  RENTAL_RETURN
}

enum AdjustmentReason {
  NEW_STOCK_RECEIVED
  SUPPLIER_RETURN_CREDIT
  FOUND_ITEMS
  DAMAGED_GOODS
  THEFT_SHRINKAGE
  EXPIRED_ITEMS
  CUSTOMER_RETURN_DEFECTIVE
  PHYSICAL_COUNT_CORRECTION
  SYSTEM_ERROR_CORRECTION
  TRANSFER_CORRECTION
  OTHER
  RENTAL_DAMAGE
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  AUTO_APPROVED
  REJECTED
  CANCELLED
}

enum AdjustmentType {
  ADD
  REMOVE
  ADJUST
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOID_TRANSACTION
  REFUND
  STOCK_ADJUSTMENT
  RENTAL_CREATE
  RENTAL_RETURN
  RENTAL_CLOSE
}

enum CustomerSource {
  CRM
  POS
  ANONYMOUS
}

enum CustomerSyncState {
  SYNCED
  PENDING
  CONFLICT
  FAILED
}

enum EntityMappingType {
  CUSTOMER
  BUSINESS
  TRANSACTION
}

enum EntityType {
  customer
  transaction
  product
  business
  rental
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
  BONUS
}

enum QueueStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  RETRY
}

enum RentalStatus {
  DRAFT
  ACTIVE
  OVERDUE
  PARTIALLY_RETURNED
  RETURNED
  CLOSED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  DAMAGE
  TRANSFER
  WRITE_OFF
  RENTAL_OUT
  RENTAL_RETURN
}

enum SyncPriority {
  HIGH
  NORMAL
  LOW
}

